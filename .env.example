# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (Neon recommended)
DATABASE_URL=postgresql://user:password@host/dbname

# ── Binance ──────────────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com

# ── Anthropic (Claude API) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Worker ───────────────────────────────────────────────────
WORKER_PORT=8000
LOG_LEVEL=INFO

# ── Feature Flags ────────────────────────────────────────────
AGENTS_ENABLED=true
EVOLUTION_ENABLED=true
